{% extends 'base.html.twig' %}

{% block title %}{{ lesson.title }} / {{ lesson.course.title }} / StudyOn{% endblock %}

{% block body %}
    <h1>{{ lesson.title }}</h1>

    <p>Курс: <a href="{{ path('app_course_show', {'id': lesson.course.id}) }}">{{ lesson.course.title }}</a></p>

    <div>
        {{ lesson.content|raw }}
    </div>

    <a href="{{ path('app_lesson_edit', {'id': lesson.id}) }}">Редактировать</a>

    {{ include('lesson/_delete_form.html.twig') }}
{% endblock %}
