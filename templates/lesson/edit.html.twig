{% extends 'base.html.twig' %}

{% block title %}{{ lesson.title }} / {{ lesson.course.title }} / StudyOn{% endblock %}

{% block header %}/ {{ lesson.course.title }} / Редактирование урока{% endblock %}

{% block body %}
    <h1>{{ lesson.title }}</h1>

    {{ include('lesson/_form.html.twig', {'button_label': 'Сохранить'}) }}

    <div class="d-flex flex-wrap gap-2 align-items-center">
        <a href="{{ path('app_lesson_show', {'id': lesson.id}) }}" class="btn btn-outline-secondary">
            Назад
        </a>
        {{ include('lesson/_delete_form.html.twig') }}
    </div>
{% endblock %}