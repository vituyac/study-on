{% extends 'base.html.twig' %}

{% block title %}{{ course.title }} / StudyOn{% endblock %}

{% block body %}
    <h1>{{ course.title }}</h1>
    <p>{{ course.description }}</p>

    <div>
        {% for lesson in course.lessons %}
            <p>{{ loop.index }}. <a href="{{ path('app_lesson_show', {'id': lesson.id}) }}">{{ lesson.title }}</a></p>
        {% else %}
            <p>Уроков ещё нет</p>
        {% endfor %}
    </div>

    <a href="{{ path('app_course_index') }}">К списку курсов</a>

    <a href="{{ path('app_course_edit', {'id': course.id}) }}">Редактировать курс</a>

    <a href="{{ path('app_lesson_new', {'id': course.id}) }}">Добавить урок</a>

    {{ include('course/_delete_form.html.twig') }}
{% endblock %}
